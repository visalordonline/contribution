rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────
    // Users collection — users can only manage their own profile
    // ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ────────────────────────────────────────────────
    // Main data: anyone authenticated can read/write their own data only
    // ────────────────────────────────────────────────
    match /artifacts/{appId}/users/{targetUserId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == targetUserId;
    }

    // Explicitly deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  
     // Allow authenticated users to read/write their own user document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Allow authenticated users to read all artifacts/contributors
    match /artifacts/{appId}/users/{userId}/januarycontributors/{contributorId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    // Allow reading all users collection (needed for admin dashboard)
    match /users/{userId} {
      allow read: if request.auth != null;
    }

    // Catch-all for other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}